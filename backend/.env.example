# Auth
JWT_SECRET=your-jwt-secret-min-32-chars

# Neon PostgreSQL — sslmode=require is mandatory
DATABASE_URL=postgresql://neondb_owner:your-neon-password@ep-your-endpoint-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require

CORS_ORIGINS=http://localhost:4202
ENVIRONMENT=development

# Resend email service
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Frontend URL (used in password reset email links)
FRONTEND_URL=http://localhost:4200
